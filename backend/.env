PROJECT_NAME="Online Auction"
API_V1_STR="/api/v1"

# Database Configuration - Khớp với service 'db-master'
# Lưu ý: SE luôn ưu tiên kết nối vào Master để đảm bảo Write/Read ổn định ban đầu
POSTGRES_SERVER=db-master
POSTGRES_USER=admin
POSTGRES_PASSWORD=vt4pOiNt5H3V32EypcSBN5U3m0y4VxwE
POSTGRES_DB=auction_db
POSTGRES_PORT=5434

# Kafka Configuration - Khớp với 'kafka-0' và 'kafka-1'
# SE khai báo cả 2 node để đảm bảo tính High Availability
KAFKA_BOOTSTRAP_SERVERS=kafka-0:9092,kafka-1:9192

# Redis Configuration - Khớp với service 'redis-server'
REDIS_HOST=redis-server
REDIS_PORT=6379